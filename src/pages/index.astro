---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
const entries = await getCollection('articles');
---
<BaseLayout title="学术搜索评测" description="学术搜索引擎评测（Google Scholar/ResearchGate/Sci-Hub/知网/万方）">
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="font-heading text-4xl text-primary leading-tight">学术搜索评测</h1>
    <p class="text-lg text-muted mt-4">学术搜索引擎评测（Google Scholar/ResearchGate/Sci-Hub/知网/万方）</p>
    <div class="mt-12">{entries.map((entry) => <ArticleCard entry={entry} />)}</div>
  </section>
</BaseLayout>